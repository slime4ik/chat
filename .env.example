# Copy to .env and fill in. Never commit the real .env.
#
# The whole app (React SPA + API + WebSocket) is served by Django/daphne on one
# port (default 8000). Put TLS / a reverse proxy in front separately if needed.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Hosts allowed to reach the app. "*" is the simplest; or list your domain/IP.
DJANGO_ALLOWED_HOSTS=*
LOG_LEVEL=INFO
# Public port to expose (host side).
HTTP_PORT=8000

# --- CORS / CSRF ---
# SPA and API share an origin, so CORS isn't needed. CSRF only matters for the
# Django admin over a domain — list it here if you use admin behind a domain.
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=

# --- PostgreSQL ---
POSTGRES_DB=messenger
POSTGRES_USER=messenger
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (channel layer) ---
REDIS_URL=redis://redis:6379/0

# --- Media / uploads ---
MEDIA_ROOT=/app/media
MAX_CHUNK_SIZE=5242880            # 5 MB per chunk
MAX_UPLOAD_SIZE=2147483648        # 2 GB max file
